Algoritmo Lecc17_Act3_Inc1
    // Definimos las variables para almacenar y recorrer
    Definir fila, columna, num, suma Como Entero
    Definir tabla Como Entero
    Dimension tabla[4,3]
    
    // Recorremos las filas
    Para fila = 1 Hasta 4 Hacer
        suma = 0
        // Recorremos las columnas
        Para columna = 1 Hasta 3 Hacer
            // Pedimos un dato al usuario
            Escribir "Ingrese un número: "
            Leer num
            // Lo asignamos en la matriz
            tabla[fila, columna] = num
            // Sumamos el valor
            suma = suma + num
        FinPara
        // Mostramos la suma de la fila
        Escribir "La suma de la fila ", fila, " es ", suma
    FinPara
FinAlgoritmo
